# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/aniceta?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Plain password used when ADMIN_PASSWORD_HASH is not set (good enough for dev)
ADMIN_PASSWORD=change-this-password
# (Optional) bcrypt hash of your password for production
# Generate with: node -e "const b=require('bcryptjs');b.hash('yourpw',10).then(console.log)"
# ADMIN_PASSWORD_HASH=$2b$10$...

# ── Cloudinary (for image uploads) ───────────────────────────────────────────
# Sign up free at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your frontend Vercel URL in production
CORS_ORIGIN=https://anecitalawfirm.vercel.app
